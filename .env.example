# PostgreSQL connection settings
# Copy this file to .env and adjust values as needed. .env is gitignored.

POSTGRES_USER=analytics
POSTGRES_PASSWORD=changeme
POSTGRES_DB=claude_code_analytics
POSTGRES_PORT=5432
POSTGRES_HOST=postgres

# Full DSN, kept in sync with the individual vars above.
# Used directly by the etl/api services once they exist.
DATABASE_URL=postgresql://analytics:changeme@postgres:5432/claude_code_analytics
